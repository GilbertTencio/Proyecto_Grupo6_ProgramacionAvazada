@model WebApplicationAPP.Models.Comercio

@{
    ViewData["Title"] = "Registrar Comercio";
}

<h2>Registrar Comercio</h2>

<form asp-action="Create">

    <div class="form-group">

        <label asp-for="Identificacion"></label>

        <input asp-for="Identificacion" class="form-control" />

        <span asp-validation-for="Identificacion" class="text-danger"></span>

    </div>


    <div class="form-group">

        <label>Tipo Identificación</label>

        <select asp-for="TipoIdentificacion" class="form-control">

            <option value="1">Física</option>

            <option value="2">Jurídica</option>

        </select>

    </div>


    <div class="form-group">

        <label asp-for="Nombre"></label>

        <input asp-for="Nombre" class="form-control" />

        <span asp-validation-for="Nombre" class="text-danger"></span>

    </div>


    <div class="form-group">

        <label>Tipo de Comercio</label>

        <select asp-for="TipoDeComercio" class="form-control">

            <option value="1">Restaurantes</option>

            <option value="2">Supermercados</option>

            <option value="3">Ferreterías</option>

            <option value="4">Otros</option>

        </select>

    </div>


    <div class="form-group">

        <label asp-for="Telefono"></label>

        <input asp-for="Telefono" class="form-control" />

        <span asp-validation-for="Telefono" class="text-danger"></span>

    </div>


    <div class="form-group">

        <label asp-for="CorreoElectronico"></label>

        <input asp-for="CorreoElectronico" class="form-control" />

        <span asp-validation-for="CorreoElectronico" class="text-danger"></span>

    </div>


    <div class="form-group">

        <label asp-for="Direccion"></label>

        <input asp-for="Direccion" class="form-control" />

        <span asp-validation-for="Direccion" class="text-danger"></span>

    </div>

    <br>

    <button type="submit" class="btn btn-success">
        Registrar
    </button>

    <a asp-action="Index" class="btn btn-secondary">
        Volver
    </a>

</form>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}