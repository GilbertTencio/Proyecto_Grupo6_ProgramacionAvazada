@model IEnumerable<WebApplicationAPP.Models.Comercio>

@{
    ViewData["Title"] = "Comercios";
}

<h2>Lista de Comercios</h2>

<p>
    <a asp-action="Create" class="btn btn-primary">Registrar Comercio</a>
</p>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Identificación</th>
            <th>Tipo Identificación</th>
            <th>Nombre</th>
            <th>Tipo Comercio</th>
            <th>Teléfono</th>
            <th>Correo</th>
            <th>Estado</th>
            <th>Acciones</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var item in Model)
        {
            <tr>

                <td>@item.Identificacion</td>

                <td>
                    @(item.TipoIdentificacion == 1 ? "Física" : "Jurídica")
                </td>

                <td>@item.Nombre</td>

                <td>
                    @(item.TipoDeComercio == 1 ? "Restaurantes" :
                                    item.TipoDeComercio == 2 ? "Supermercados" :
                                    item.TipoDeComercio == 3 ? "Ferreterías" : "Otros")
                </td>

                <td>@item.Telefono</td>

                <td>@item.CorreoElectronico</td>

                <td>
                    @(item.Estado ? "Activo" : "Inactivo")
                </td>

                <td>

                    <a asp-action="Edit" asp-route-id="@item.IdComercio" class="btn btn-warning btn-sm">
                        Editar
                    </a>

                    <a asp-action="Details" asp-route-id="@item.IdComercio" class="btn btn-info btn-sm">
                        Detalles
                    </a>

                </td>

            </tr>
        }
    </tbody>

</table>