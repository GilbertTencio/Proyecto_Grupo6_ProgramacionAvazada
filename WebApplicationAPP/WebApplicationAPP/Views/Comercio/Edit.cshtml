@model WebApplicationAPP.Models.Comercio

@{
    ViewData["Title"] = "Editar Comercio";
}

<h2>Editar Comercio</h2>

<form asp-action="Edit">

    <input type="hidden" asp-for="IdComercio" />

    <div class="form-group">

        <label>Identificación</label>

        <input asp-for="Identificacion" class="form-control" readonly />

    </div>


    <div class="form-group">

        <label>Tipo Identificación</label>

        <input asp-for="TipoIdentificacion" class="form-control" readonly />

    </div>


    <div class="form-group">

        <label asp-for="Nombre"></label>

        <input asp-for="Nombre" class="form-control" />

    </div>


    <div class="form-group">

        <label>Tipo Comercio</label>

        <select asp-for="TipoDeComercio" class="form-control">

            <option value="1">Restaurantes</option>

            <option value="2">Supermercados</option>

            <option value="3">Ferreterías</option>

            <option value="4">Otros</option>

        </select>

    </div>


    <div class="form-group">

        <label asp-for="Telefono"></label>

        <input asp-for="Telefono" class="form-control" />

    </div>


    <div class="form-group">

        <label asp-for="CorreoElectronico"></label>

        <input asp-for="CorreoElectronico" class="form-control" />

    </div>


    <div class="form-group">

        <label asp-for="Direccion"></label>

        <input asp-for="Direccion" class="form-control" />

    </div>


    <div class="form-group">

        <label>Estado</label>

        <select asp-for="Estado" class="form-control">

            <option value="true">Activo</option>

            <option value="false">Inactivo</option>

        </select>

    </div>

    <br>

    <button type="submit" class="btn btn-success">
        Guardar Cambios
    </button>

    <a asp-action="Index" class="btn btn-secondary">
        Volver
    </a>

</form>